PORT=5000
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=social_chunks
VECTOR_STORE=qdrant

# Set one of these — OpenAI takes priority if both are set
OPENAI_API_KEY=
GEMINI_API_KEY=

# OpenAI models (used when OPENAI_API_KEY is set)
# EMBEDDING_MODEL=text-embedding-3-small
# CHAT_MODEL=gpt-4.1-mini

# Gemini models (used when GEMINI_API_KEY is set, free tier works)
EMBEDDING_MODEL=text-embedding-004
CHAT_MODEL=gemini-2.0-flash

# GitHub OAuth sign-in — create an OAuth App at https://github.com/settings/developers
# Authorization callback URL must exactly match GITHUB_CALLBACK_URL below.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5173/api/auth/github/callback

# Random secret used to sign session cookies — e.g. `openssl rand -hex 32`
SESSION_SECRET=
